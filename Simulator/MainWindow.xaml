<Window x:Class="Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Simulator"
        Title="Simulator — Control pompe M43"
        Height="720" Width="1180"
        MinHeight="640" MinWidth="980"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN -->
        <StackPanel Grid.Column="0">

            <TextBlock Text="SIMULATOR — CONTROL POMPE (M43)"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,16" />

            <!-- STATUS -->
            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="STATUS SISTEM" Style="{StaticResource HeaderText}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MOD" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding ModeText}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ALARMĂ" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="14" Height="14" Fill="{Binding AlarmBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding AlarmText}" FontSize="20" FontWeight="SemiBold"
                                           Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CONSUM Y1" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding ConsumptionText}" FontSize="24" FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- POMPE -->
            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="POMPE (M1–M4) ȘI DISPONIBILITATE (P1–P4)" Style="{StaticResource HeaderText}" />
                    <ItemsControl ItemsSource="{Binding Pumps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Lamp P -->
                                    <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center">
                                        <Ellipse Width="22" Height="22" Fill="{Binding LampBrush}"
                                                 Stroke="#3F5061" StrokeThickness="1" />
                                        <TextBlock Text="{Binding LampLabel}" FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>

                                    <!-- Motor M -->
                                    <Border Grid.Column="1" CornerRadius="6"
                                            Background="{Binding MotorBrush}"
                                            Padding="6,8" HorizontalAlignment="Center" MinWidth="60">
                                        <TextBlock Text="{Binding Label}" FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center" Foreground="#0F1419" />
                                    </Border>

                                    <!-- Status -->
                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                               VerticalAlignment="Center" Margin="14,0,0,0"
                                               FontSize="14" />

                                    <!-- Toggle availability -->
                                    <Button Grid.Column="3" Content="{Binding ButtonLabel}"
                                            Click="OnTogglePump"
                                            Tag="{Binding Index}"
                                            ToolTip="Comută disponibilitatea pompei" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- COMENZI -->
            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="COMENZI ȘI SETĂRI" Style="{StaticResource HeaderText}" />

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button x:Name="BtnPower" Content="Pornește sistem (Ein/Aus)" Click="OnTogglePower"
                                Style="{StaticResource OkButton}" MinWidth="200" />
                        <Button x:Name="BtnEStop" Content="S0 — STOP TOATE" Click="OnStopAll"
                                Style="{StaticResource DangerButton}" MinWidth="200" Margin="12,0,0,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                        <Button x:Name="BtnB2" Content="Simulează defect B2" Click="OnToggleB2"
                                MinWidth="200"
                                ToolTip="Forțează scenariul de redundanță: senzorul B2 'cade', controlul nu mai oprește pompele, presiunea urcă, B1 declanșează alarma 5s." />
                        <Border CornerRadius="4" Padding="10,6" Margin="12,0,0,0" Background="#0B121A">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="{Binding B2StatusBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding B2StatusText}" FontWeight="SemiBold"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Y1 — Rată consum"
                                   VerticalAlignment="Center" FontSize="13" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="8" SmallChange="0.1" LargeChange="0.5"
                                Value="{Binding ConsumptionRate, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="False"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding ConsumptionText}"
                                   TextAlignment="Right" VerticalAlignment="Center" FontSize="13" />
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Presiune setată (B2)"
                                   VerticalAlignment="Center" FontSize="13" />
                        <Slider Grid.Column="1" Minimum="1" Maximum="9" SmallChange="0.1" LargeChange="0.5"
                                Value="{Binding Setpoint, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="False"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SetpointText}"
                                   TextAlignment="Right" VerticalAlignment="Center" FontSize="13" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- RIGHT COLUMN -->
        <StackPanel Grid.Column="2">

            <TextBlock Text="PRESIUNE LIVE"
                       Style="{StaticResource HeaderText}"
                       Margin="0,4,0,8" />

            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding PressureText}"
                               FontSize="56" FontWeight="Bold"
                               Foreground="{Binding PressureStatusBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Run Text="Setpoint: " Foreground="{StaticResource MutedBrush}" />
                        <Run Text="{Binding SetpointText, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>

                    <Grid Height="20">
                        <Border Background="#0B121A" CornerRadius="10" />
                        <Border Background="{Binding PressureStatusBrush}" CornerRadius="10"
                                HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding StringFormat="0">
                                    <Binding Path="PressureBarPercent" />
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Grid>

                    <TextBlock Text="Bara: % din presiunea maximă a sistemului"
                               FontSize="10" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="EXPLICAȚII RAPIDE" Style="{StaticResource HeaderText}" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#94A3B8" LineHeight="20">
                        <Run Text="•" FontWeight="Bold" /> <Run Text="S0" FontWeight="SemiBold" /> oprește toate pompele.<LineBreak/>
                        <Run Text="•" FontWeight="Bold" /> <Run Text="S1–S4" FontWeight="SemiBold" /> comută disponibilitatea fiecărei pompe.<LineBreak/>
                        <Run Text="•" FontWeight="Bold" /> În AUTO, pompele pornesc/opresc câte una la 1 s pentru a urmări presiunea setată.<LineBreak/>
                        <Run Text="•" FontWeight="Bold" /> Pentru demonstrarea alarmei: apasă „Simulează defect B2" → senzorul principal cade, pompele continuă, B1 declanșează alarma la 10.5 bar pentru 5 s.<LineBreak/>
                        <Run Text="•" FontWeight="Bold" /> Uzura egală: se pornește prima pompă oprită cel mai mult, se oprește prima pompă rulată cel mai mult.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="REȚEA" Style="{StaticResource HeaderText}" />
                    <TextBlock FontSize="12" Foreground="#94A3B8">
                        <Run Text="Sim → Monitor (TCP 3000)" /><LineBreak/>
                        <Run Text="Monitor → WebAPI (HTTP 5000)" /><LineBreak/>
                        <Run Text="WebAPI → WEB (HTTP)" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
